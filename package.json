{
  "name": "relay",
  "version": "0.4.5",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "check": "bash scripts/check.sh",
    "check:frontend": "bash scripts/check/frontend.sh",
    "lint": "biome lint .",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "check:rust": "bash scripts/check/rust.sh",
    "reset:workspace": "concurrently --names \"node,rust\" --prefix-colors \"cyan,yellow\" \"rimraf dist build node_modules bun.lockb && bun install\" \"cargo clean && cargo build\"",
    "postinstall": "bun scripts/postinstall.ts",
    "prepare": "simple-git-hooks",
    "commitlint": "commitlint",
    "setup": "bun scripts/setup.ts",
    "dev": "cargo run -p relay-server -- --dev",
    "build": "vite build",
    "build:server": "cargo build -p relay-server --release",
    "build:all": "bun run build && bun run build:server",
    "start": "cargo run -p relay-server -- --static-dir dist",
    "pre-commit": "bun scripts/hooks/pre-commit.ts"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/brygada-1918": "^5.2.8",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.12",
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "fast-deep-equal": "^3.1.3",
    "framer-motion": "^12.34.3",
    "ignore": "^7.0.5",
    "immer": "^10.2.0",
    "lucide-react": "^1.8.0",
    "material-file-icons": "^2.4.0",
    "nanoid": "^3.3.11",
    "pdfjs-dist": "^5.4.296",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-pdf": "^10.3.0",
    "react-scan": "^0.4.3",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.0.6",
    "use-sync-external-store": "^1.6.0",
    "usehooks-ts": "^3.1.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "web-tree-sitter": "^0.25.10",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^19.8.1",
    "@derekstride/tree-sitter-sql": "^0.3.11",
    "@tailwindcss/vite": "^4.2.2",
    "@tlaplus/tree-sitter-tlaplus": "^1.0.0",
    "@tree-sitter-grammars/tree-sitter-markdown": "^0.3.0",
    "@tree-sitter-grammars/tree-sitter-vue": "github:tree-sitter-grammars/tree-sitter-vue",
    "@tree-sitter-grammars/tree-sitter-yaml": "^0.7.0",
    "@tree-sitter-grammars/tree-sitter-zig": "^1.0.0",
    "@types/bun": "^1.3.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.17",
    "tree-sitter-bash": "^0.23.0",
    "tree-sitter-c": "^0.23.0",
    "tree-sitter-c-sharp": "^0.23.0",
    "tree-sitter-cli": "^0.26.6",
    "tree-sitter-cpp": "^0.23.0",
